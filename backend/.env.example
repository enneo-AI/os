# enneo OS Backend — Environment (nie committen, auf dem Hosting als Env-Vars setzen)

# Anthropic (MVP: Aleksas persönlicher Key, später Firmen-Key)
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional: Model-Override (Default: claude-sonnet-5)
ENNI_MODEL=claude-sonnet-5

# Supabase-Projekt "enneo OS" (aiwhomrvspfxotkllngz)
SUPABASE_URL=https://aiwhomrvspfxotkllngz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# GitLab read-only Connector (enneo-GitLab)
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=glpat-...

# Server
PORT=8080
# Erlaubte Frontend-Origin für CORS (Komma-separiert für mehrere)
FRONTEND_ORIGIN=https://os.enneo.ai,https://enneo-os.netlify.app
SITE_URL=https://os.enneo.ai

# Slack OAuth (einmalige enneo-OS-App; Nutzer verbinden danach nur noch per Login)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://enneo-os-backend-production.up.railway.app/api/oauth/slack/callback
# `openssl rand -base64 32` — verschlüsselt Provider-Tokens zusätzlich in der DB
CONNECTOR_ENCRYPTION_KEY=

# USD→EUR Kurs für cost_eur in llm_usage (statisch, reicht für Transparenz)
EUR_PER_USD=0.92
